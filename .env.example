# Required only for live investigations and live scenario analysis.
CEREBRAS_API_KEY=your_cerebras_api_key

# Recommended for indexed first-party and independent evidence enrichment.
TAVILY_API_KEY=your_tavily_api_key

# Optional. Defaults to the model used by the reference Cerebras project.
CEREBRAS_MODEL=gemma-4-31b

# Optional locally and on Vercel. Vercel's system URL is used automatically.
NEXT_PUBLIC_APP_URL=http://localhost:3000
