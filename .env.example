# Required when Cerebras is selected for live analysis.
CEREBRAS_API_KEY=your_cerebras_api_key

# Recommended for indexed first-party and independent evidence enrichment.
TAVILY_API_KEY=your_tavily_api_key

# Optional. Defaults to the model used by the reference Cerebras project.
CEREBRAS_MODEL=gemma-4-31b

# Optional locally and on Vercel. Vercel's system URL is used automatically.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Required when OpenAI is selected for live analysis.
OPENAI_API_KEY=your_openai_api_key

# Override when a different Responses API model is preferred.
OPENAI_MODEL=gpt-5.6-terra

# Required when Anthropic is selected for live analysis.
ANTHROPIC_API_KEY=your_anthropic_api_key

# Pinned Haiku 4.5 snapshot for reproducible behavior.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
